{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FDvoice",
  "version": "0.1.0",
  "identifier": "com.fdvoice.dictation",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FDvoice",
        "width": 920,
        "height": 620,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "focus": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/fdvoice_whisper.py"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
